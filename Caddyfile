# Caddyfile for both testing and production
dealerchatbot.duckdns.org, chatbot.dealerdeck.ai {
    # Proxy all traffic to the FastAPI application running on port 8001
    reverse_proxy localhost:8001 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    # Enable automatic HTTPS via Let's Encrypt
    tls support@dealerdeck.ai
}
